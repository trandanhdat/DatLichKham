@* Views/Message/ChatWithDoctor.cshtml *@
@model List<ClinicBookingSystem.Models.Message>
@{
    Layout = null;
    int currentUserId = (int)ViewBag.CurrentUserId;
    int receiverId = (int)ViewBag.ReceiverId;
    string receiverName = ViewBag.ReceiverName ?? "Bác sĩ";
    string avatarLetter = receiverName.Length > 0 ? receiverName.Substring(0, 1).ToUpper() : "B";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Chat - @receiverName</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            height: 100%;
            overflow: hidden;
            background: #f0f2f5;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        .chat-wrap {
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        .chat-header {
            flex-shrink: 0;
            background: #fff;
            border-bottom: 1px solid #e9ecef;
            padding: 10px 16px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .chat-body {
            flex: 1 1 0;
            overflow-y: auto;
            padding: 16px 20px;
            background: #f0f2f5;
            max-width: 760px;
            width: 100%;
            margin: 0 auto;
            align-self: center;
        }

        .chat-footer {
            flex-shrink: 0;
            background: #fff;
            border-top: 1px solid #e9ecef;
            padding: 10px 16px;
            max-width: 760px;
            width: 100%;
            margin: 0 auto;
        }

        /* Bubbles */
        .chat-bubble {
            border-radius: 18px;
            padding: 9px 14px;
            font-size: .9rem;
            line-height: 1.5;
            word-break: break-word;
            white-space: pre-wrap;
            max-width: 220px;
            display: inline-block;
        }

        .bubble-mine {
            background: #0d6efd;
            color: #fff;
            border-bottom-right-radius: 4px;
        }

        .bubble-other {
            background: #fff;
            color: #212529;
            border-bottom-left-radius: 4px;
            box-shadow: 0 1px 3px rgba(0,0,0,.08);
        }

        /* Avatar */
        .avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: #0d6efd;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: .9rem;
            flex-shrink: 0;
        }

        .avatar-sm {
            width: 30px;
            height: 30px;
            font-size: .75rem;
        }

        /* Date divider */
        .date-divider {
            text-align: center;
            margin: 14px 0;
        }

            .date-divider span {
                background: #fff;
                border: 1px solid #dee2e6;
                border-radius: 20px;
                padding: 3px 14px;
                font-size: .72rem;
                color: #6c757d;
            }

        /* Input */
        #msgInput {
            flex: 1;
            border: none;
            background: #f0f2f5;
            border-radius: 22px;
            padding: 10px 16px;
            font-size: .9rem;
            resize: none;
            max-height: 100px;
            overflow-y: auto;
            outline: none;
            transition: background .2s;
        }

            #msgInput:focus {
                background: #e9ecef;
            }

        /* Send button */
        .send-btn {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: #0d6efd;
            border: none;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            cursor: pointer;
            transition: background .2s, transform .1s;
        }

            .send-btn:hover {
                background: #0a58ca;
            }

            .send-btn:active {
                transform: scale(.94);
            }

            .send-btn:disabled {
                background: #adb5bd;
                cursor: default;
            }

        /* Back button */
        .btn-back {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #f0f2f5;
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #495057;
            text-decoration: none;
            flex-shrink: 0;
            transition: background .2s;
        }

            .btn-back:hover {
                background: #dee2e6;
                color: #212529;
            }
    </style>
</head>
<body>
    <div class="chat-wrap">

        <div class="chat-header">
            <a href="/Message/MyMessages" class="btn-back">
                <i class="bi bi-arrow-left"></i>
            </a>
            <div class="avatar">@avatarLetter</div>
            <div>
                <div style="font-weight:600; font-size:.95rem;">@receiverName</div>
                <small id="connStatus" style="color:#adb5bd; font-size:.72rem;">Đang kết nối...</small>
            </div>
        </div>

        <div class="chat-body" id="chatBody">

            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted" id="emptyState">
                    <i class="bi bi-chat-heart-fill" style="font-size:2.5rem; opacity:.2;"></i>
                    <p class="mt-2 small">Hãy bắt đầu cuộc trò chuyện!</p>
                </div>
            }
            else
            {
                DateTime? prevDate = null;
                foreach (var msg in Model)
                {
                    bool isMine = msg.UserId == currentUserId;

                    if (prevDate == null || msg.CreatedAt.Date != prevDate.Value.Date)
                    {
                        prevDate = msg.CreatedAt.Date;
                        string lbl = msg.CreatedAt.Date == DateTime.Today ? "Hôm nay"
                        : msg.CreatedAt.Date == DateTime.Today.AddDays(-1) ? "Hôm qua"
                        : msg.CreatedAt.ToString("dd/MM/yyyy");
                        <div class="date-divider"><span>@lbl</span></div>
                    }

                    if (isMine)
                    {
                        <div class="d-flex justify-content-end mb-2">
                            <div>
                                <div class="chat-bubble bubble-mine">@msg.Content</div>
                                <div class="text-end mt-1">
                                    <small class="text-muted" style="font-size:.7rem;">
                                        @msg.CreatedAt.ToString("HH:mm")
                                        <i class="bi @(msg.Status == "Replied" ? "bi-check2-all text-primary" : "bi-check2") ms-1"></i>
                                    </small>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-start align-items-end gap-2 mb-2">
                            <div class="avatar avatar-sm">@avatarLetter</div>
                            <div>
                                <div class="chat-bubble bubble-other">@msg.Content</div>
                                <div class="mt-1">
                                    <small class="text-muted" style="font-size:.7rem;">@msg.CreatedAt.ToString("HH:mm")</small>
                                </div>
                            </div>
                        </div>
                    }
                }
            }

            <div id="chatEnd"></div>
        </div>

        <div class="chat-footer">
            @Html.AntiForgeryToken()
            <div class="d-flex align-items-end gap-2">
                <textarea id="msgInput" rows="1" placeholder="Nhập tin nhắn..." autocomplete="off"></textarea>
                <button id="sendBtn" class="send-btn">
                    <i class="bi bi-send-fill" id="sendIcon"></i>
                </button>
            </div>
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const CURRENT_USER_ID = @currentUserId;
        const RECEIVER_ID     = @receiverId;
        const AVATAR          = "@avatarLetter";
        const TOKEN           = document.querySelector('input[name="__RequestVerificationToken"]').value;

        function scrollBottom(smooth) {
            document.getElementById('chatEnd').scrollIntoView({ behavior: smooth ? 'smooth' : 'instant' });
        }

        function escHtml(s) {
            const d = document.createElement('div');
            d.textContent = s;
            return d.innerHTML;
        }

        let lastDate = '';

        function appendBubble(msg, isMine) {
            const empty = document.getElementById('emptyState');
            if (empty) empty.remove();

            const anchor = document.getElementById('chatEnd');

            const dateKey = msg.isToday ? '__today__' : msg.dateStr;
            if (dateKey !== lastDate) {
                lastDate = dateKey;
                const label = msg.isToday ? 'Hôm nay' : msg.dateStr;
                anchor.insertAdjacentHTML('beforebegin',
                    `<div class="date-divider"><span>${label}</span></div>`);
            }

            if (isMine) {
                anchor.insertAdjacentHTML('beforebegin', `
                    <div class="d-flex justify-content-end mb-2">
                        <div>
                            <div class="chat-bubble bubble-mine">${escHtml(msg.content)}</div>
                            <div class="text-end mt-1">
                                <small class="text-muted" style="font-size:.7rem;">
                                    ${msg.createdAt}
                                    <i class="bi bi-check2 ms-1"></i>
                                </small>
                            </div>
                        </div>
                    </div>`);
            } else {
                anchor.insertAdjacentHTML('beforebegin', `
                    <div class="d-flex justify-content-start align-items-end gap-2 mb-2">
                        <div class="avatar avatar-sm">${AVATAR}</div>
                        <div>
                            <div class="chat-bubble bubble-other">${escHtml(msg.content)}</div>
                            <div class="mt-1">
                                <small class="text-muted" style="font-size:.7rem;">${msg.createdAt}</small>
                            </div>
                        </div>
                    </div>`);
            }

            scrollBottom(true);
        }

        function startSignalR() {
            if (typeof signalR === 'undefined') {
                document.getElementById('connStatus').textContent = 'Chế độ thường';
                return;
            }

            const conn = new signalR.HubConnectionBuilder()
                .withUrl("/chatHub")
                .withAutomaticReconnect()
                .build();

            conn.on("ReceiveMessage", msg => {
                if (msg.senderId === RECEIVER_ID) appendBubble(msg, false);
            });

            conn.onreconnecting(() => {
                document.getElementById('connStatus').textContent = 'Đang kết nối lại...';
                document.getElementById('connStatus').style.color = '#ffc107';
            });
            conn.onreconnected(() => {
                document.getElementById('connStatus').textContent = '● Đang hoạt động';
                document.getElementById('connStatus').style.color = '#198754';
            });

            conn.start()
                .then(() => conn.invoke("JoinUserGroup", CURRENT_USER_ID.toString()))
                .then(() => {
                    document.getElementById('connStatus').textContent = '● Đang hoạt động';
                    document.getElementById('connStatus').style.color = '#198754';
                })
                .catch(err => {
                    console.warn("SignalR chưa sẵn sàng:", err.message);
                    document.getElementById('connStatus').textContent = 'Chế độ thường';
                    document.getElementById('connStatus').style.color = '#6c757d';
                });
        }

        startSignalR();

        async function sendMessage() {
            const input   = document.getElementById('msgInput');
            const content = input.value.trim();
            if (!content) return;

            const btn  = document.getElementById('sendBtn');
            const icon = document.getElementById('sendIcon');
            btn.disabled   = true;
            icon.className = 'bi bi-hourglass-split';

            try {
                const res  = await fetch('/Message/SendChatMessage', {
                    method:  'POST',
                    headers: {
                        'Content-Type':             'application/x-www-form-urlencoded',
                        'X-Requested-With':         'XMLHttpRequest',
                        'RequestVerificationToken': TOKEN
                    },
                    body: new URLSearchParams({ receiverId: RECEIVER_ID, content })
                });
                const data = await res.json();
                if (data.success) {
                    appendBubble(data, true);
                    input.value        = '';
                    input.style.height = 'auto';
                }
            } catch (e) {
                console.error('Send error:', e);
            } finally {
                btn.disabled   = false;
                icon.className = 'bi bi-send-fill';
                input.focus();
            }
        }

        document.getElementById('sendBtn').addEventListener('click', sendMessage);
        document.getElementById('msgInput').addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
        });
        document.getElementById('msgInput').addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 100) + 'px';
        });

        scrollBottom(false);
        document.getElementById('msgInput').focus();
    </script>
</body>
</html>
