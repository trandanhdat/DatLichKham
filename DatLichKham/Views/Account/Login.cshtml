@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 75vh;">
        <div class="col-md-5 col-lg-4">

            <div class="card-custom p-4 shadow-lg mt-4">

                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                         style="width:60px; height:60px; background:var(--primary-light);">
                        <i class="bi bi-person-lock text-primary fs-3"></i>
                    </div>
                    <h4 class="fw-bold text-dark mb-1">Đăng Nhập</h4>
                    <p class="text-muted small mb-0">Chào mừng bạn quay trở lại với ClinicBooking</p>
                </div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success border-0 small rounded-3 mb-3">
                        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                    </div>
                }
                @if (ViewBag.ErrorMessage != null)
                {
                    <div class="alert alert-danger border-0 small rounded-3 mb-3">
                        <i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.ErrorMessage
                    </div>
                }

                <form asp-action="Login" method="post">

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Tên đăng nhập</label>
                        <div class="input-icon-wrap">
                            <span class="icon-left"><i class="bi bi-person" style="font-size:16px;"></i></span>
                            <input name="username" type="text"
                                   class="form-control form-control-modern"
                                   placeholder="Nhập tên đăng nhập" required autofocus />
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label fw-semibold small mb-0">Mật khẩu</label>
                            <a href="#" class="text-decoration-none small text-primary opacity-75">Quên mật khẩu?</a>
                        </div>
                        <div class="input-icon-wrap">
                            <span class="icon-left"><i class="bi bi-lock" style="font-size:16px;"></i></span>
                            <input id="passwordInput" name="password" type="password"
                                   class="form-control form-control-modern has-icon-right"
                                   placeholder="••••••••" required />
                            <button type="button" class="icon-right" onclick="togglePassword()">
                                <i id="eyeIcon" class="bi bi-eye" style="font-size:16px;"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="rememberMe" />
                            <label class="form-check-label small text-secondary" for="rememberMe">Ghi nhớ đăng nhập</label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary btn-modern w-100 shadow-sm">
                        Đăng nhập <i class="bi bi-arrow-right ms-2"></i>
                    </button>

                </form>

                <div class="text-center mt-4">
                    <p class="small text-secondary mb-0">
                        Chưa có tài khoản?
                        <a asp-action="Register" class="text-primary fw-bold text-decoration-none">Đăng ký ngay</a>
                    </p>
                </div>

            </div>

            <div class="text-center mt-3">
                <a asp-controller="Home" asp-action="Index" class="text-muted small text-decoration-none">
                    <i class="bi bi-house-door me-1"></i> Quay lại trang chủ
                </a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePassword() {
            const input = document.getElementById('passwordInput');
            const icon = document.getElementById('eyeIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye';
            }
        }
    </script>
}
