@model ClinicBookingSystem.Models.Appointment

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0">Xác nhận hủy lịch khám</h5>
                </div>
                <div class="card-body">
                    <p>Bạn có chắc chắn muốn hủy lịch khám với bác sĩ <strong>@Model.Doctor?.FullName</strong>?</p>
                    <ul class="list-unstyled">
                        <li><strong>Ngày:</strong> @Model.AppointmentDate.ToString("dd/MM/yyyy")</li>
                        <li><strong>Giờ:</strong> @Model.AppointmentTime.ToString(@"hh\:mm")</li>
                        <li><strong>Lý do:</strong> @Model.Reason</li>
                    </ul>

                    <form asp-action="Cancel" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger">Xác nhận hủy ngay</button>
                            <a asp-action="MyAppointments" class="btn btn-outline-secondary">Quay lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>