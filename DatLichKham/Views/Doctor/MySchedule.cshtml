@model IEnumerable<ClinicBookingSystem.Models.Appointment>

<div class="container mt-4 animate-fade-in">
    <div class="d-flex align-items-center mb-4">
        <div class="bg-primary-light rounded-circle p-3 me-3">
            <i class="bi bi-calendar-check text-primary fs-4"></i>
        </div>
        <div>
            <h3 class="fw-bold mb-0">Lịch khám của tôi</h3>
            <p class="text-muted small mb-0">Quản lý và cập nhật trạng thái các cuộc hẹn với bệnh nhân</p>
        </div>
    </div>

    <div class="table-modern-wrapper">
        <table class="table table-modern mb-0">
            <thead>
                <tr>
                    <th>Bệnh nhân</th>
                    <th>Ngày khám</th>
                    <th>Giờ khám</th>
                    <th class="d-none d-md-table-cell">Lý do</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-light text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold me-2" style="width: 35px; height: 35px; font-size: 0.8rem;">
                                    @(item.User?.FullName?.Substring(0, 1).ToUpper() ?? "U")
                                </div>
                                <span class="fw-bold text-dark">@item.User?.FullName</span>
                            </div>
                        </td>

                        <td class="text-muted">
                            <i class="bi bi-calendar3 me-1"></i> @item.AppointmentDate.ToString("dd/MM/yyyy")
                        </td>

                        <td class="text-muted">
                            <i class="bi bi-clock me-1"></i> @item.AppointmentTime.ToString(@"hh\:mm")
                        </td>

                        <td class="d-none d-md-table-cell text-truncate" style="max-width: 200px;">
                            @item.Reason
                        </td>

                        <td class="text-center">
                            @if (item.Status == "Pending")
                            {
                                <span class="badge-status status-pending"><i class="bi bi-hourglass-split me-1"></i> Chờ duyệt</span>
                            }
                            else if (item.Status == "Confirmed")
                            {
                                <span class="badge-status status-approved"><i class="bi bi-check-circle me-1"></i> Đã xác nhận</span>
                            }
                            else if (item.Status == "Completed")
                            {
                                <span class="badge-status status-approved" style="background: #e7f5ff; color: #0d6efd;">
                                    <i class="bi bi-flag me-1"></i> Hoàn thành
                                </span>
                            }
                            else if (item.Status == "Cancelled")
                            {
                                <span class="badge-status status-cancelled"><i class="bi bi-x-circle me-1"></i> Đã hủy</span>
                            }
                        </td>

                        <td class="text-end">
                            <form asp-action="ConfirmAppointment" method="post" class="d-inline-block">
                                <input type="hidden" name="id" value="@item.Id" />

                                <select name="status"
                                        class="form-select form-select-sm form-control-modern border-0 bg-light"
                                        style="width: 140px; cursor: pointer;"
                                        onchange="this.form.submit()">
                                    <option selected disabled>-- Cập nhật --</option>
                                    <option value="Confirmed">Xác nhận</option>
                                    <option value="Completed">Hoàn thành</option>
                                    <option value="Cancelled">Hủy bỏ</option>
                                </select>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-bottom shadow-sm">
            <i class="bi bi-inbox text-muted display-1"></i>
            <p class="mt-3 text-muted">Hiện tại chưa có lịch hẹn nào.</p>
        </div>
    }
</div>