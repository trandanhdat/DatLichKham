<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClinicBooking</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --primary-color: #0d6efd;
            --secondary-color: #6c757d;
        }

        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Navbar Styling */
        .navbar {
            transition: all 0.3s ease;
            padding: 0.8rem 1rem;
        }

        .navbar-brand {
            font-weight: 800;
            letter-spacing: -0.5px;
            color: var(--primary-color) !important;
            display: flex;
            align-items: center;
        }

        .nav-link {
            font-weight: 500;
            padding: 0.5rem 1rem !important;
            transition: color 0.2s;
        }

            .nav-link:hover {
                color: var(--primary-color) !important;
            }

        /* Dropdown Customization */
        .dropdown-menu {
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
            border: 1px solid rgba(0,0,0,0.05);
            padding: 0.5rem;
        }

        .dropdown-item {
            border-radius: 8px;
            padding: 0.6rem 1rem;
            margin-bottom: 2px;
        }

            .dropdown-item:hover {
                background-color: #f0f7ff;
                color: var(--primary-color);
            }

        /* Footer */
        footer {
            background-color: #fff;
            padding: 2rem 0;
            margin-top: 5rem;
        }

        .btn-auth {
            border-radius: 50px;
            padding: 0.5rem 1.5rem;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top shadow-sm">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-heart-pulse-fill me-2"></i>ClinicBooking
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @{
                            var userRole = Context.Session.GetString("Role");
                        }

                        @if (userRole == "Admin")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-danger fw-bold" href="#" id="adminMenu" data-bs-toggle="dropdown">
                                    <i class="bi bi-gear-fill me-1"></i>Quản trị
                                </a>
                                <ul class="dropdown-menu shadow">
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Doctors"><i class="bi bi-people me-2"></i>Quản lý Bác sĩ</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Appointments"><i class="bi bi-calendar-event me-2"></i>Quản lý Lịch hẹn</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Messages"><i class="bi bi-envelope me-2"></i>Quản lý Tin nhắn</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Accounts"><i class="bi bi-person-lock me-2"></i>Quản lý Tài khoản</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    @* ── USER SECTION ── *@
                    <div class="d-flex align-items-center">
                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            <div class="dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center bg-light rounded-pill px-3 py-1"
                                   href="#" id="userDropdown" data-bs-toggle="dropdown">
                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px;">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                    <span class="fw-semibold text-dark">@Context.Session.GetString("Username")</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end mt-2">
                                    @if (userRole == "Admin")
                                    {
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Bảng điều khiển</a></li>
                                    }
                                    @if (userRole == "Doctor")
                                    {
                                        <li><a class="dropdown-item" asp-controller="Doctor" asp-action="MySchedule"><i class="bi bi-calendar-check me-2"></i>Lịch khám</a></li>
                                        <li><a class="dropdown-item" asp-controller="Message" asp-action="DoctorMessages"><i class="bi bi-chat-left-text me-2"></i>Tin nhắn BN</a></li>
                                    }
                                    @if (userRole == "User")
                                    {
                                        <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>Hồ sơ của tôi</a></li>
                                        <li><a class="dropdown-item" asp-controller="Message" asp-action="MyMessages"><i class="bi bi-chat-dots me-2"></i>Tin nhắn</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger fw-bold" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="nav-link text-dark me-3 fw-semibold" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            <a class="btn btn-primary btn-auth shadow-sm" asp-controller="Account" asp-action="Register">Tham gia ngay</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="container my-4 flex-grow-1">
        @RenderBody()
    </main>
    <footer class="text-center text-lg-start border-top">
        <div class="container text-center">
            <p class="mb-1 fw-bold text-primary">ClinicBooking &copy; 2026</p>
            <p class="small text-muted mb-0">Hệ thống đặt lịch khám bệnh trực tuyến thông minh.</p>
            <div class="mt-2">
                <a asp-action="Privacy" class="text-decoration-none text-muted small me-3">Chính sách bảo mật</a>
                <a href="#" class="text-decoration-none text-muted small">Liên hệ</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>