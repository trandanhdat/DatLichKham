@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid mt-4 animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded-4 shadow-sm">
        <div>
            <h1 class="h4 mb-0 fw-bold text-primary">Hệ thống quản trị Clinic</h1>
            <p class="text-muted small mb-0">Chào mừng trở lại, <span class="fw-semibold text-dark">@ViewBag.FullName</span></p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="text-end d-none d-md-block">
                <div class="small fw-bold">@DateTime.Now.ToString("dd/MM/yyyy")</div>
                <div class="text-muted small">Hôm nay</div>
            </div>
            <div class="bg-primary-light p-2 rounded-circle">
                <i class="bi bi-person-badge-fill text-primary fs-4"></i>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-2">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-blue-soft p-3 rounded-3 me-3 text-primary">
                        <i class="bi bi-people fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Bác sĩ</div>
                        <div class="h5 mb-0 fw-bold">12</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-2">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-green-soft p-3 rounded-3 me-3 text-success">
                        <i class="bi bi-calendar-check fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Lịch khám</div>
                        <div class="h5 mb-0 fw-bold">48</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-2">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-orange-soft p-3 rounded-3 me-3 text-warning">
                        <i class="bi bi-chat-dots fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Tin nhắn mới</div>
                        <div class="h5 mb-0 fw-bold">7</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card border-0 shadow-sm rounded-4 p-2">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-red-soft p-3 rounded-3 me-3 text-danger">
                        <i class="bi bi-star fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Đánh giá</div>
                        <div class="h5 mb-0 fw-bold">4.9</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h5 class="fw-bold mb-3 text-dark">Quản lý hệ thống</h5>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 card-hover">
                <div class="card-body p-4 text-center">
                    <div class="avatar-lg bg-primary text-white rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center">
                        <i class="bi bi-person-vcard fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Quản lý Bác sĩ</h5>
                    <p class="text-muted small">Thêm mới, chỉnh sửa thông tin và chuyên khoa của đội ngũ bác sĩ.</p>
                    <a asp-action="Doctors" class="btn btn-outline-primary rounded-pill px-4 w-100 mt-2">Truy cập</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 card-hover">
                <div class="card-body p-4 text-center">
                    <div class="avatar-lg bg-success text-white rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center">
                        <i class="bi bi-calendar2-week fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Lịch hẹn Khám</h5>
                    <p class="text-muted small">Theo dõi trạng thái lịch khám và điều phối lịch hẹn của bệnh nhân.</p>
                    <a asp-action="Appointments" class="btn btn-outline-success rounded-pill px-4 w-100 mt-2">Truy cập</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 h-100 card-hover">
                <div class="card-body p-4 text-center">
                    <div class="avatar-lg bg-warning text-dark rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center">
                        <i class="bi bi-chat-left-text fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Hộp thư hỗ trợ</h5>
                    <p class="text-muted small">Trả lời thắc mắc của bệnh nhân và quản lý các cuộc hội thoại.</p>
                    <a asp-action="Messages" class="btn btn-outline-dark rounded-pill px-4 w-100 mt-2">Truy cập</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Bảng màu bổ trợ */
    .bg-blue-soft {
        background-color: #e7f1ff;
    }

    .bg-green-soft {
        background-color: #e8f5e9;
    }

    .bg-orange-soft {
        background-color: #fff3e0;
    }

    .bg-red-soft {
        background-color: #ffebee;
    }

    .bg-primary-light {
        background-color: #f0f7ff;
    }

    .avatar-lg {
        width: 70px;
        height: 70px;
    }

    /* Hiệu ứng Hover cho Card */
    .card-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .card-hover:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 20px rgba(0,0,0,0.1) !important;
        }

    .btn-modern {
        transition: all 0.2s;
    }

    .animate-fade-in {
        animation: fadeIn 0.5s ease-in-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>