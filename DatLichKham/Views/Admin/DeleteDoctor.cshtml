@model ClinicBookingSystem.Models.Doctor

@{
    ViewData["Title"] = "Xác nhận xóa bác sĩ";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Xác nhận vô hiệu hóa</h4>
                </div>
                <div class="card-body">
                    <p class="lead">Bạn có chắc chắn muốn ngừng hoạt động cho bác sĩ này không?</p>

                    <div class="bg-light p-3 rounded mb-4">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Họ tên:</dt>
                            <dd class="col-sm-8 fw-bold">@Model.FullName</dd>

                            <dt class="col-sm-4">Chuyên khoa:</dt>
                            <dd class="col-sm-8">@Model.Specialty</dd>

                            <dt class="col-sm-4">Email:</dt>
                            <dd class="col-sm-8">@Model.Email</dd>
                        </dl>
                    </div>

                    <div class="alert alert-warning small">
                        <i class="bi bi-info-circle"></i> <strong>Lưu ý:</strong> Bác sĩ này sẽ không còn xuất hiện trên danh sách đặt lịch của bệnh nhân nhưng dữ liệu lịch hẹn cũ vẫn được giữ lại.
                    </div>

                    <form asp-action="DeleteDoctor" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger px-4">Xác nhận xóa</button>
                            <a asp-action="Doctors" class="btn btn-outline-secondary">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>