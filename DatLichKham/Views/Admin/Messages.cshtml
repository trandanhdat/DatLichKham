@model IEnumerable<ClinicBookingSystem.Models.Message>

<div class="container-fluid mt-4 animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded-4 shadow-sm">
        <div>
            <h4 class="mb-0 fw-bold text-primary"><i class="bi bi-headset me-2"></i>Trung tâm Hỗ trợ & Tư vấn</h4>
            <p class="text-muted small mb-0">Quản lý các yêu cầu tư vấn từ bệnh nhân</p>
        </div>
        <div class="d-flex gap-2">
            <span class="badge bg-warning-light text-warning border border-warning-subtle px-3 py-2 rounded-pill">
                @Model.Count(m => m.Status == "Pending") yêu cầu mới
            </span>
        </div>
    </div>

    <div class="row">
        @foreach (var item in Model.OrderBy(m => m.Status == "Replied"))
        {
            bool isPending = item.Status == "Pending";

            <div class="col-12 mb-3">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden position-relative @(isPending ? "border-start border-warning border-5" : "opacity-75")">
                    <div class="card-body p-4">
                        <div class="row align-items-start">
                            <div class="col-md-3 border-end">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="avatar-sm bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold me-2">
                                        @item.User?.FullName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div class="fw-bold text-dark">@item.User?.FullName</div>
                                </div>
                                <div class="text-muted small mb-1"><i class="bi bi-clock me-1"></i> @item.CreatedAt.ToString("HH:mm dd/MM/yyyy")</div>

                                @if (isPending)
                                {
                                    <span class="badge bg-warning text-dark rounded-pill small mt-2">Chưa xử lý</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-success border border-success-subtle rounded-pill small mt-2">Đã hoàn thành</span>
                                }
                            </div>

                            <div class="col-md-6 px-4">
                                <div class="message-content mb-3">
                                    <h6 class="text-muted small text-uppercase fw-bold mb-2">Nội dung yêu cầu:</h6>
                                    <p class="mb-0 text-dark">@item.Content</p>
                                </div>

                                @if (!isPending)
                                {
                                    <div class="reply-content p-3 rounded-3 bg-light border-start border-primary border-3 mt-2">
                                        <h6 class="text-primary small fw-bold mb-1">Phản hồi từ hệ thống:</h6>
                                        <p class="mb-0 small italic">@item.AdminReply</p>
                                        <div class="text-muted mt-1" style="font-size: 0.7rem;">
                                            Ngày phản hồi: @item.RepliedAt?.ToString("g")
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="col-md-3 text-end d-flex flex-column gap-2 justify-content-center h-100">
                                <a asp-controller="Message" asp-action="ChatWithDoctor" asp-route-receiverId="@item.UserId" class="btn btn-outline-primary rounded-pill btn-sm shadow-sm">
                                    <i class="bi bi-chat-fill me-1"></i> Nhắn tin trực tiếp
                                </a>

                                <a asp-action="ReplyMessage" asp-route-id="@item.Id" class="btn @(isPending ? "btn-primary" : "btn-light") rounded-pill btn-sm shadow-sm">
                                    <i class="bi bi-reply-fill me-1"></i> @(isPending ? "Gửi phản hồi nhanh" : "Sửa phản hồi")
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .bg-warning-light {
        background-color: #fffef0;
    }

    .avatar-sm {
        width: 35px;
        height: 35px;
        font-size: 0.9rem;
    }

    .card {
        transition: all 0.3s ease;
    }

        .card:hover {
            transform: translateX(5px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.05) !important;
        }

    .italic {
        font-style: italic;
    }
</style>