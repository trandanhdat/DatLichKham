@model IEnumerable<ClinicBookingSystem.Models.User>

<div class="container-fluid mt-4 animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded-4 shadow-sm">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-action="Dashboard">Admin</a></li>
                    <li class="breadcrumb-item active">Tài khoản</li>
                </ol>
            </nav>
            <h4 class="mb-0 fw-bold text-primary">Quản lý Hệ thống Tài khoản</h4>
        </div>
        <a asp-action="CreateAccount" class="btn btn-primary btn-modern rounded-pill px-4 shadow-sm">
            <i class="bi bi-person-plus-fill me-2"></i>Tạo tài khoản mới
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white py-3 border-0">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <div class="input-group input-group-sm" style="max-width: 350px;">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                        <input type="text" id="accountSearch" class="form-control bg-light border-0" placeholder="Tìm tên đăng nhập, họ tên hoặc email...">
                    </div>
                </div>

            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Người dùng</th>
                        <th>Thông tin liên hệ</th>
                        <th>Vai trò (Role)</th>
                        <th>Ngày tham gia</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="accountTableBody">
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-light text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold me-3 border">
                                        @u.FullName.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@u.Username</div>
                                        <div class="text-muted small">@u.FullName</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="small"><i class="bi bi-envelope me-2 text-muted"></i>@u.Email</div>
                                <div class="small mt-1"><i class="bi bi-telephone me-2 text-muted"></i>@u.Phone</div>
                            </td>
                            <td>
                                @switch (u.Role)
                                {
                                    case "Admin":
                                        <span class="badge rounded-pill bg-danger-light text-danger border border-danger-subtle px-3">
                                            <i class="bi bi-shield-lock me-1"></i> Admin
                                        </span>
                                        break;
                                    case "Doctor":
                                        <span class="badge rounded-pill bg-primary-light text-primary border border-primary-subtle px-3">
                                            <i class="bi bi-person-badge me-1"></i> Doctor
                                        </span>
                                        break;
                                    default:
                                        <span class="badge rounded-pill bg-info-light text-info border border-info-subtle px-3">
                                            <i class="bi bi-person me-1"></i> Patient
                                        </span>
                                        break;
                                }
                            </td>
                            <td class="text-muted small">
                                @u.CreatedAt.ToString("dd/MM/yyyy")
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm rounded-3">
                                    <a asp-action="EditAccount" asp-route-id="@u.Id"
                                       class="btn btn-white btn-sm text-primary" title="Sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="DeleteAccount" asp-route-id="@u.Id"
                                       class="btn btn-white btn-sm text-danger"
                                       title="Xóa" onclick="return confirm('Bạn có chắc chắn muốn xóa tài khoản này?')">
                                        <i class="bi bi-trash3"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-primary-light {
        background-color: #f0f7ff;
    }

    .bg-danger-light {
        background-color: #fff5f5;
    }

    .bg-info-light {
        background-color: #f0faff;
    }

    .avatar-sm {
        width: 40px;
        height: 40px;
        flex-shrink: 0;
    }

    .table thead th {
        font-weight: 600;
        letter-spacing: 0.5px;
        border-bottom: none;
    }

    .table tbody tr {
        transition: background-color 0.2s;
        border-bottom: 1px solid #f8f9fa;
    }

        .table tbody tr:hover {
            background-color: #fcfdfe !important;
        }

    .btn-white {
        background: white;
        border: 1px solid #eee;
    }

        .btn-white:hover {
            background: #f8f9fa;
        }

    .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(5px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script>
    // Search function
    document.getElementById('accountSearch').addEventListener('keyup', function() {
        let value = this.value.toLowerCase();
        let rows = document.querySelectorAll('#accountTableBody tr');
        rows.forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(value) ? '' : 'none';
        });
    });
</script>