@model ClinicBookingSystem.Models.User

@{
    ViewData["Title"] = "Tạo tài khoản hệ thống";
}

<div class="container-fluid mt-4 mb-5 animate-fade-in">
    <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-8">
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Dashboard">Admin</a></li>
                    <li class="breadcrumb-item"><a asp-action="Accounts">Tài khoản</a></li>
                    <li class="breadcrumb-item active">Tạo mới</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-success py-3 px-4 text-white border-0">
                    <div class="d-flex align-items-center">
                        <div class="bg-white bg-opacity-25 rounded-circle p-2 me-3">
                            <i class="bi bi-person-plus-fill fs-4"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold">Tạo tài khoản mới</h5>
                            <small class="opacity-75">Thiết lập quyền truy cập cho nhân sự hoặc bác sĩ</small>
                        </div>
                    </div>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="CreateAccount" method="post" id="createAccountForm">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3 small"></div>

                        <h6 class="text-success fw-bold text-uppercase mb-4 small" style="letter-spacing: 1px;">
                            <i class="bi bi-shield-lock-fill me-2"></i>Thông tin đăng nhập
                        </h6>

                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <label asp-for="Username" class="form-label fw-semibold">Tên đăng nhập</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-person"></i></span>
                                    <input asp-for="Username" class="form-control border-start-0 ps-0 shadow-sm" placeholder="Ví dụ: nguyenvana" />
                                </div>
                                <span asp-validation-for="Username" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Mật khẩu</label>
                                <input type="password" name="password" class="form-control shadow-sm" placeholder="••••••••" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Xác nhận mật khẩu</label>
                                <input type="password" name="confirmPassword" class="form-control shadow-sm" placeholder="••••••••" />
                            </div>
                        </div>

                        <h6 class="text-success fw-bold text-uppercase mb-4 small" style="letter-spacing: 1px;">
                            <i class="bi bi-person-lines-fill me-2"></i>Thông tin cá nhân & Quyền hạn
                        </h6>

                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <label asp-for="FullName" class="form-label fw-semibold">Họ và Tên</label>
                                <input asp-for="FullName" id="FullName" class="form-control shadow-sm" placeholder="Nguyễn Văn A" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-semibold">Email</label>
                                <input asp-for="Email" id="Email" class="form-control shadow-sm" placeholder="name@example.com" />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Phone" class="form-label fw-semibold">Số điện thoại</label>
                                <input asp-for="Phone" id="Phone" class="form-control shadow-sm" placeholder="09xxxxxxxx" />
                            </div>

                            <div class="col-12">
                                <label asp-for="Role" class="form-label fw-bold text-primary">Vai trò hệ thống (Role)</label>
                                <select asp-for="Role" id="RoleSelect" class="form-select border-primary-subtle shadow-sm bg-primary bg-opacity-10">
                                    <option value="User">Người dùng (User)</option>
                                    <option value="Doctor">Bác sĩ (Doctor)</option>
                                    <option value="Admin">Quản trị viên (Admin)</option>
                                </select>
                            </div>
                        </div>

                    

                        <div class="pt-3 d-flex gap-2">
                            <button type="submit" class="btn btn-success btn-modern rounded-pill px-5 shadow-sm">
                                <i class="bi bi-check-lg me-2"></i>Xác nhận tạo
                            </button>
                            <a asp-action="Accounts" class="btn btn-light rounded-pill px-4">Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-success {
        background: linear-gradient(135deg, #198754 0%, #146c43 100%) !important;
    }

    .border-dashed {
        border-style: dashed !important;
        border-width: 2px !important;
    }

    .btn-modern {
        transition: all 0.3s;
    }

        .btn-modern:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(25, 135, 84, 0.3) !important;
        }

    .animate-fade-in {
        animation: fadeIn 0.4s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

@section Scripts {
    <script>
        document.getElementById('doctorIdSelect').addEventListener('change', function() {
            const roleSelect = document.getElementById('RoleSelect');
            if (this.value !== "") {
                roleSelect.value = "Doctor";
                roleSelect.classList.add('is-valid');
            } else {
                roleSelect.classList.remove('is-valid');
            }
        });
    </script>
}