@using DatLichKham.Services
@model PaginatedList<ClinicBookingSystem.Models.Doctor>

@{
    ViewData["Title"] = "Đội ngũ Bác sĩ";
}

<div class="container py-5 animate-up">
    <div class="row align-items-center mb-5">
        <div class="col-lg-5">
            <h2 class="fw-bold text-dark mb-1">Đội ngũ Bác sĩ</h2>
            <p class="text-muted">Tìm kiếm chuyên gia phù hợp để chăm sóc sức khỏe cho bạn</p>
        </div>
        <div class="col-lg-7">
            <form asp-action="Doctors" method="get">
                <div class="input-group shadow-sm rounded-pill overflow-hidden bg-white p-1" style="border: 1px solid #e0e0e0;">
                    <span class="input-group-text bg-transparent border-0"><i class="bi bi-search text-primary"></i></span>
                    <input type="text" name="searchString" class="form-control border-0 shadow-none"
                           placeholder="Tên bác sĩ hoặc chuyên khoa..."
                           value="@ViewData["CurrentFilter"]" />
                    @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                    {
                        <a asp-action="Doctors" class="btn btn-light border-0 px-3">Xóa</a>
                    }
                    <button type="submit" class="btn btn-primary btn-rounded px-4">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card-custom p-5 text-center">
            <img src="https://cdn-icons-png.flaticon.com/512/6134/6134065.png" style="width: 100px;" class="mb-3 opacity-50">
            <h5 class="text-muted">Rất tiếc, chúng tôi không tìm thấy bác sĩ nào khớp với từ khóa.</h5>
            <a asp-action="Doctors" class="btn btn-link">Xem tất cả bác sĩ</a>
        </div>
    }

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card-custom h-100 p-3">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-4">
                            <div class="flex-shrink-0 position-relative">
                                <img src="https://cdn-icons-png.flaticon.com/512/3774/3774299.png"
                                     alt="Doctor" class="rounded-circle bg-light p-2 shadow-sm" style="width: 70px; height: 70px; object-fit: cover;">
                                <span class="position-absolute bottom-0 end-0 bg-success border border-white rounded-circle" style="width: 15px; height: 15px;"></span>
                            </div>
                            <div class="ms-3">
                                <h5 class="mb-0 fw-bold text-dark">@item.FullName</h5>
                                <span class="badge bg-primary-soft text-primary rounded-pill">@item.Specialty</span>
                            </div>
                        </div>

                        <div class="space-y-2 mb-4">
                            <div class="d-flex align-items-center text-muted small mb-2">
                                <i class="bi bi-envelope-at me-2 text-primary"></i> @item.Email
                            </div>
                            <div class="d-flex align-items-center text-muted small">
                                <i class="bi bi-telephone me-2 text-primary"></i> @item.Phone
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-transparent border-0 pt-0">
                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            <div class="d-flex gap-2">
                                <a asp-action="DoctorDetails" asp-route-id="@item.Id"
                                   class="btn btn-light btn-modern w-100 border text-secondary">Chi tiết</a>
                                <a asp-controller="Appointment" asp-action="Create" asp-route-doctorId="@item.Id"
                                   class="btn btn-primary btn-modern w-100">Đặt lịch</a>
                            </div>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-modern w-100">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập để đặt lịch
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-5">
            <ul class="pagination justify-content-center custom-pagination">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link shadow-sm mx-1 rounded" asp-action="Doctors"
                       asp-route-pageNumber="@(Model.PageIndex - 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item mx-1 @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link shadow-sm rounded" asp-action="Doctors"
                           asp-route-pageNumber="@i"
                           asp-route-searchString="@ViewData["CurrentFilter"]">@i</a>
                    </li>
                }

                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link shadow-sm mx-1 rounded" asp-action="Doctors"
                       asp-route-pageNumber="@(Model.PageIndex + 1)"
                       asp-route-searchString="@ViewData["CurrentFilter"]">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

<style>
    /* Bổ sung một chút cho pagination */
    .custom-pagination .page-link {
        border: none;
        color: var(--secondary);
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .custom-pagination .page-item.active .page-link {
        background-color: var(--primary);
        color: white;
    }

    .bg-primary-soft {
        background-color: #e7f1ff;
    }
</style>